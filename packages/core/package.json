{
  "name": "@context-ray/core",
  "version": "0.1.0",
  "description": "Deterministic coding-agent context discovery and analysis",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@context-ray/schema": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "^3.0.1",
    "gray-matter": "^4.0.3",
    "minimatch": "^10.0.3",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/iarna__toml": "^2.0.5",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2"
  }
}
